# =============================================================================
# OKX Opportunity Scanner - Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env to git.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=okx-scanner
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false                       # true for dev only
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=okx
POSTGRES_PASSWORD=okx_dev_password
POSTGRES_DB=okx_scanner
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_ECHO=false                    # true to log all SQL (dev only)

# Full DSN (overrides individual settings if provided)
DATABASE_URL=postgresql://okx:okx_dev_password@localhost:5432/okx_scanner

# -----------------------------------------------------------------------------
# Redis Cache & Queue
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# Full DSN (overrides individual settings if provided)
# REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# OKX API Credentials
# -----------------------------------------------------------------------------
# Get from https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_API_BASE_URL=https://www.okx.com
OKX_WS_PUBLIC_URL=wss://ws.okx.com:8443/ws/v5/public
OKX_WS_PRIVATE_URL=wss://ws.okx.com:8443/ws/v5/private
OKX_USE_TESTNET=true                   # true: demo trading, false: real

# -----------------------------------------------------------------------------
# Scanner Configuration
# -----------------------------------------------------------------------------
SCANNER_INTERVAL_SECONDS=60            # How often to run scan cycle
SCANNER_MAX_INSTRUMENTS=200            # Max instruments to track
SCANNER_MIN_VOLUME_24H_USD=1000000     # Filter: min 24h volume
SCANNER_QUOTE_CURRENCIES=USDT,USDC     # Comma-separated

# -----------------------------------------------------------------------------
# Strategy Engine
# -----------------------------------------------------------------------------
MOMENTUM_MIN_VOLUME_24H_USD=5000000     # Momentum: skip micro-cap (24h vol < $5M)

# -----------------------------------------------------------------------------
# Scoring & Risk
# -----------------------------------------------------------------------------
SCORING_MIN_THRESHOLD=70               # 0-100, minimum score to alert
RISK_MAX_POSITION_USD=1000
RISK_MAX_DAILY_LOSS_USD=500
RISK_MAX_CONCURRENT_POSITIONS=5

# -----------------------------------------------------------------------------
# Alerting
# -----------------------------------------------------------------------------
ALERT_ENABLED=true
ALERT_COOLDOWN_SECONDS=300             # Don't re-alert same instrument within
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
